--doc#	Quiz to teach you the compass rose
-------------------------------------------------------------------------->
<concept>
<pre>
       0-360<br>
         |  <br>
  315    N    45<br>
      NW | NE<br>
270--W---*---E--90<br>
      SW | SE<br>
   225   S   135<br>
         |  <br>
	180<br>
<question>Azimuth bearing for North is
<answer right>0 or 360 degrees</answer>
<answer>90 degrees</answer>
<answer>180 degrees</answer>
<answer>270 degrees</answer>
</question>
<question>0 degrees points:
<answer right>North</answer>
<answer>East</answer>
<answer>South</answer>
<answer>West</answer>
</question>
<question>Azimuth bearing for East is
<answer>0 or 360 degrees</answer>
<answer right>90 degrees</answer>
<answer>180 degrees</answer>
<answer>270 degrees</answer>
</question>
<question>90 degrees points:
<answer>North</answer>
<answer right>East</answer>
<answer>South</answer>
<answer>West</answer>
</question>
<question>Azimuth bearing for South is
<answer>0 or 360 degrees</answer>
<answer>90 degrees</answer>
<answer right>180 degrees</answer>
<answer>270 degrees</answer>
</question>
<question>180 degrees points:
<answer>North</answer>
<answer>East</answer>
<answer right>South</answer>
<answer>West</answer>
</question>
<question>Azimuth bearing for West is
<answer>0 or 360 degrees</answer>
<answer>90 degrees</answer>
<answer>180 degrees</answer>
<answer right>270 degrees</answer>
</question>
<question>270 degrees points:
<answer>North</answer>
<answer>East</answer>
<answer>South</answer>
<answer right>West</answer>
</question>
<question>Azimuth bearing for North East is
<answer right>45 degrees</answer>
<answer>135 degrees</answer>
<answer>225 degrees</answer>
<answer>315 degrees</answer>
</question>
<question>45 degrees points:
<answer>North East</answer>
<answer>North West</answer>
<answer>South East</answer>
<answer>South West</answer>
</question>
<question>Azimuth bearing for North West is
<answer>45 degrees</answer>
<answer>135 degrees</answer>
<answer>225 degrees</answer>
<answer right>315 degrees</answer>
</question>
<question>315 degrees points:
<answer>North East</answer>
<answer right>North West</answer>
<answer>South East</answer>
<answer>South West</answer>
</question>
<question>Azimuth bearing for South East is
<answer>45 degrees</answer>
<answer right>135 degrees</answer>
<answer>225 degrees</answer>
<answer>315 degrees</answer>
</question>
<question>135 degrees points:
<answer>North East</answer>
<answer>North West</answer>
<answer right>South East</answer>
<answer>South West</answer>
</question>
<question>Azimuth bearing for South West is
<answer>45 degrees</answer>
<answer>135 degrees</answer>
<answer right>225 degrees</answer>
<answer>315 degrees</answer>
</question>
<question>225 degrees points:
<answer>North East</answer>
<answer>North West</answer>
<answer>South East</answer>
<answer right>South West</answer>
</question>
</concept>
